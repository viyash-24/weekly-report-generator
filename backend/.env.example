# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/weekly_report_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ─── Client URL (CORS) ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
